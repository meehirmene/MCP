# FlowForge environment configuration
# Copy this to .env and fill in your values

# ─────────────────────────────────────────────
# LLM Configuration (pick one provider)
# ─────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | gemini | anthropic | ollama
LLM_MODEL=gpt-4o             # Model name for the chosen provider
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.1

# For Ollama (local, no API key needed):
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434/v1

# ─────────────────────────────────────────────
# Infrastructure (defaults work with docker-compose)
# ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FLINK_JOBMANAGER_URL=http://localhost:8081
ICEBERG_REST_URL=http://localhost:8181
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=ecommerce
POSTGRES_USER=flowforge
POSTGRES_PASSWORD=flowforge123
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=ecommerce
MONGO_USER=flowforge
MONGO_PASSWORD=flowforge123
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────
# FlowForge Settings
# ─────────────────────────────────────────────
FLOWFORGE_DEBUG=false
FLOWFORGE_LOG_LEVEL=INFO
